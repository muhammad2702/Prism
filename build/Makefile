VariableContainerTest: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 VariableContainerTest
.PHONY : VariableContainerTest

# fast build rule for target.
VariableContainerTest/fast:
	$(MAKE) $(MAKESILENT) -f test/VariableContainerTest/CMakeFiles/VariableContainerTest.dir/build.make test/VariableContainerTest/CMakeFiles/VariableContainerTest.dir/build
.PHONY : VariableContainerTest/fast

