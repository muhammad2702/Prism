<?xml version="1.0" ?>
<settings>
    <writer>writercsv</writer>
    <filename>Exp6A_Symmetric</filename>
    <case>
        <RNGSettings>
            <RNG>RandomGeneratorStdLib</RNG>
        </RNGSettings>
        <agents>
            <AgentCross>
                <count>1000</count>
                <b1>30</b1>
                <b2>60</b2>
                <A1>0.1</A1>
                <A2>0.3</A2>
                <cash>1</cash>
                <stock>1</stock>
            </AgentCross>
        </agents>
        <qoi>
            <price>
                <full/>
            </price>
            <logreturn>
                <full/>
            </logreturn>
        </qoi>
        <numsteps>1000</numsteps>
        <outputname>Cross_Sim</outputname>
        <deltaT>1</deltaT>
        <writerClass>WriterCSV</writerClass>
        <excessDemandCalculatorSettings>
            <excessDemandCalculatorClass>ExcessDemandCalculatorHarras</excessDemandCalculatorClass>
        </excessDemandCalculatorSettings>
        <priceCalculatorSettings>
            <priceCalculatorClass>PriceCalculatorCross</priceCalculatorClass>
            <theta>0.01</theta>
            <marketDepth>2</marketDepth>
        </priceCalculatorSettings>
        <dividendSettings>
            <Z1>0.005</Z1>
            <Z2>0.015</Z2>
            <interestRate>0.01</interestRate>
            <initialDividend>0.01</initialDividend>
        </dividendSettings>
        <stockExchangeClass>StockExchangeHarras</stockExchangeClass>
        <repetitions>1</repetitions>
        <startPrice>1</startPrice>
    </case>
</settings>
